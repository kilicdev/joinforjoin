<!DOCTYPE html>
<html lang="en">
  <head>
  <%- header %>
  </head>
  <body style="width: 100%;height: 100%;">
    <div class="container">
      <aside>
        <div class="top">
          <div class="logo">
            <img src="<%- base %>/images/logo.png" />
            <h2><%- csybot.config.name %></h2>
          </div>
          <div class="close" id="close-btn">
            <span class="material-icons-sharp">close</span>
          </div>
        </div>

        <div class="sidebar">
          <a href="<%- base %>" class="active">
            <span class="material-icons-sharp">grid_view</span>
            <h3>Panel</h3>
          </a>
          <a href="<%- base %>/server">
            <span class="material-icons-sharp">edit</span>
            <h3>Profil</h3>
          </a>
          <a style="color: orange;" href="<%- base %>/invite">
            <span class="material-icons-sharp">add_circle</span>
            <h3>Davet</h3>
          </a>
          <a href="<%- base %>/exit">
            <span class="material-icons-sharp">logout</span>
            <h3>Çıkış</h3>
          </a>
        </div>
      </aside>
      <!------------------ END OF ASIDE ------------------>
        
<style>
  input[type="url"] {
      display: block;
      width: 280px;
      height: calc(1.5em + 0.75rem + 2px);
      padding: 0.375rem 0.75rem;
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.5;
      color: #ad91ff;
      background: #202528;
      box-shadow: 0 2rem 3rem rgba(0, 0, 0, 0.4);
      transition: all 300ms ease;
      border: none;
  }

    input[type="submit"] {
      width: 90px;
      background: transparent;
      cursor: pointer;
      padding: 10px 20px;
      border-radius: 4px;
      box-sizing: border-box;

      border-radius: 1.2rem;
      background: #202528;
      gap: 1rem;
      box-shadow: 0 2rem 3rem rgba(0, 0, 0, 0.4);
      transition: all 300ms ease;
      color: orange;
      border: none;
      outline: none;
    }
    input[type="url"]:focus {
      border: none;
      box-shadow: none;
      outline-offset: none;
      outline: none;
    }

    .total {
      width: 100%;
      align-items: center;
    }
    .toggle {
      position: relative;
      display: block;
      width: 40px;
      height: 20px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transform: translate3d(0, 0, 0); 
    }
    .toggle:before {
      content: "";
      position: relative;
      top: 3px;
      left: 3px;
      width: 34px;
      height: 14px;
      display: block;
      background: #9A9999;
      border-radius: 8px;
      transition: background .2s ease; }
    .toggle span {
      position: absolute;
      top: 0;
      left: 0;
      width: 20px;
      height: 20px;
      display: block;
      background: white;
      border-radius: 10px;
      box-shadow: 0 3px 8px rgba(154, 153, 153, 0.5);
      transition: all .2s ease; 
    }
    .toggle span:before {
      content: "";
      position: absolute;
      display: block;
      margin: -18px;
      width: 56px;
      height: 56px;
      background: rgba(79, 46, 220, 0.5);
      border-radius: 50%;
      transform: scale(0);
      opacity: 1;
      pointer-events: none; 
    }

    #cbx:checked + .toggle:before {
      background: #947ADA; 
    }

    #cbx:checked + .toggle span {
      background: #4F2EDC;
      transform: translateX(20px);
      transition: all 0.2s cubic-bezier(0.8, 0.4, 0.3, 1.25), background 0.15s ease;
      box-shadow: 0 3px 8px rgba(79, 46, 220, 0.2); 
    }
      #cbx:checked + .toggle span:before {
        transform: scale(1);
        opacity: 0;
        transition: all .4s ease; 
    }
  .maining {
    background: var(--color-white);
    padding: var(--card-padding);
    border-radius: var(--card-border-radius);
    margin-top: 1rem;
    box-shadow: var(--box-shadow);
    transition: all 300ms ease;
  }
  
</style>
        
      <main>
        <h1>Panel</h1>
        <% if(!enabled) { %>
          <div class="maining" style="display: relative;margin-left: 20%;width: 40rem">
          
              <center>
                <div class="total">
                    <span style="margin-left: 18px;background-color: transparent; color: red; font-size: 14px;font-Weight: 500;display: inline-block;">Önce "Profile" Sayfasından Sunucunuzun Davetini Belirleyin!</span>
                </div>
              </center>
          </div>
          <% } else { %>
            
            
              <!--
              <center>
                <div class="total">
                  <div>
                    <div style="display: inline-block;" class="profile-photo">
                      <img src="<%- `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` %>" />
                    </div>
                    <span style="margin-left: 18px;background-color: transparent; color: black; font-size: 20px;font-Weight: 100;display: inline-block;">Eşleme Aranıyor ..</span>
                    <div style="margin-left: 20px;display: inline-block;" class="profile-photo">
                      <img src="https://cdn.discordapp.com/embed/avatars/0.png" />
                    </div>
                  </div>
                </div>
              </center>
              -->
            <div id="changeid">
              <div style="display: relative;margin-left: 40%;width: 25rem; margin-top: 10%;">
                <center>
                    <div>
                      <div style="display: inline-block;">
                        <input style="width: 160px;height: 50px;" type="submit" onclick="start();" value="Başlat">
                      </div>
                    </div>
                </center>
              </div>
            </div>
          <% } %>
        <span id="test"></span>
        <!------------ END OF INSIGHTS -------------->
      </main>
      <!----------------- END OF MAIN -------------------->
      <div class="right">
        <div class="top">
          <button id="menu-btn">
            <span class="material-icons-sharp">menu</span>
          </button>
          <div class="profile">
            <div class="info">
              <p>Selam, <b><%- csybot.filter(`${user.username}#${user.discriminator}`); %></b></p>
              <% if(csybot.config.owners.includes(user.id)) { %>
                <small class="text-muted" style="cursor:pointer;color: #ad91ff;font-size: 12px;">Admin</small>
              <% } else { %>
                <small class="text-muted" style="cursor:pointer;color: #ad91ff;font-size: 12px;">Üye</small>
              <% } %>
            </div>
            <div class="profile-photo">
              <img id="profile1" src="<%- profile %>" onerror="document.getElementById('profile1').src = 'https://cdn.discordapp.com/embed/avatars/0.png'" />
            </div>
          </div>
        </div>
      </div>
    </div>

  
  <script src="http://code.jquery.com/jquery-2.0.3.min.js"></script>
  <script src="https://api.csycraft.com/libs/js/panel.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <%- realfooter %>
  <script>
    const change = document.getElementById("changeid");
    const test = document.getElementById("test");
    var socket = io();

    socket.on('disconnect', (reason) => {
      socket.disconnect();
      socket = null;
    });
    
    function start() {
      
      change.innerHTML = `<div class="maining" style="display: relative;margin-left: 20%;width: 40rem">
              <center>
                <div class="total">
                  <div>
                    <div style="display: inline-block;" class="profile-photo">
                      <img id="profile2" src="<%- profile %>" onerror="document.getElementById('profile2').src = 'https://cdn.discordapp.com/embed/avatars/0.png'" />
                    </div>
                    <span id="textstr" style="margin-left: 18px;background-color: transparent; color: black; font-size: 20px;font-Weight: 100;display: inline-block;">Eşleme Aranıyor ..</span>
                    <div style="margin-left: 20px;display: inline-block;" class="profile-photo">
                      <img id="changingavatars" src="https://cdn.discordapp.com/embed/avatars/0.png" onerror="document.getElementById('changingavatars').src = 'https://cdn.discordapp.com/embed/avatars/0.png'" />
                    </div>
                    <div id="renew"></div>
                  </div>
                </div>
              </center>
            </div>`;
      const changingavatars = document.getElementById("changingavatars");
      const textstr = document.getElementById("textstr");
      const renew = document.getElementById("renew");
      var changenumber = 0;
      setInterval(function() {
        changingavatars.src = `https://cdn.discordapp.com/embed/avatars/${changenumber}.png`;
        if(changenumber >= 5 && changenumber != 88) {
          changenumber = 0;
        } else if (changenumber != 88) {
          changenumber++;
        }
      }, 2000);
      
      /*
      $.ajax({url: `<%- base %>/api/find/<%- token %>`, success: function(result){
        
        changenumber = 88;
        changingavatars.src = `https://cdn.discordapp.com/avatars/${result.id}/${result.avatar}.png`
        textstr.innerHTML = "Düzenleniyor..";
        
      }});*/
      
      
      socket.emit('login', `<%- token %>`);
      
      socket.on('update', (result) => {
        if(result.code == 3) {
          textstr.innerHTML = result.message;
        } else if (result.code == 4) {
          changenumber = 88;
          changingavatars.src = `https://cdn.discordapp.com/avatars/${result.id}/${result.avatar}.png`
          textstr.innerHTML = result.message;
          setTimeout(function() {
            start();
          }, 5000);
        } else if (result.code == 5) {
          textstr.innerHTML = result.message;
          changenumber = 88;
          changingavatars.src = `https://cdn.discordapp.com/avatars/${result.id}/${result.avatar}.png`
        }
      })
      
      
    }
    
    <% if(enabled && spin) { %>
          start();                             
    <% } %>
    
  </script>
  </body>
</html>